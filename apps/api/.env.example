NODE_ENV=development
PORT=4000

MONGODB_URI=mongodb://127.0.0.1:27017/workra

# generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=replace_me_with_long_random_string
REFRESH_TOKEN_SECRET=replace_me_with_another_long_random_string

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

WEB_ORIGIN=http://localhost:3000
COOKIE_DOMAIN=

LOG_LEVEL=debug

# ai layer (optional). leave ANTHROPIC_API_KEY unset to run workra entirely on
# the deterministic fallbacks — the report / recap / session suggestion endpoints
# still respond, they just return the templated narrative instead of an llm one.
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5
AI_TIMEOUT_MS=8000
AI_MAX_TOKENS=400

# storage: "local" writes to disk (default), "s3" uses any s3-compatible service.
# when using local, STORAGE_LOCAL_DIR is the upload directory relative to the api root.
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads
# s3 settings (required when STORAGE_DRIVER=s3)
# STORAGE_BUCKET=workra-files
# STORAGE_REGION=auto
# STORAGE_ENDPOINT=https://your-r2-or-s3-endpoint
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_PUBLIC_URL=https://cdn.example.com
STORAGE_SIGNED_URL_TTL=900
STORAGE_MAX_UPLOAD_BYTES=26214400

# error tracking (optional). set SENTRY_DSN to enable.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
